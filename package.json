{
  "name": "@oneworks/site",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:homepage": "pnpm --filter @oneworks/homepage dev",
    "dev:docs": "pnpm --filter @oneworks/docs dev",
    "build": "pnpm build:homepage && pnpm build:docs && pnpm assemble",
    "build:homepage": "pnpm --filter @oneworks/homepage build",
    "build:docs": "pnpm --filter @oneworks/docs build",
    "assemble": "node scripts/assemble-pages.mjs",
    "check": "pnpm --filter @oneworks/homepage check && pnpm --filter @oneworks/docs build"
  }
}
