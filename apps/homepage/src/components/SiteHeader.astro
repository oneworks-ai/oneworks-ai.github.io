---
import { createMobiusSvg } from '@oneworks/icon/svg'

type Props = {
  brandClassName?: string
  className?: string
  downloadUrl?: string
  docsUrl?: string
  i18n?: boolean
  showCornerDownload?: boolean
}

const {
  brandClassName = 'room-corner-brand',
  className = 'site-header',
  docsUrl = import.meta.env.PUBLIC_DOCS_URL ?? '/docs/',
  downloadUrl = 'https://github.com/oneworks-ai/app/releases',
  i18n = false,
  showCornerDownload = false
} = Astro.props

const githubUrl = 'https://github.com/oneworks-ai/app'
const pwaUrl = 'https://oneworks-ai.github.io/pwa/'
const i18nAttrs = (key: string) => i18n ? { 'data-i18n': key } : {}
const appendDocsPath = (baseUrl: string, path: string) =>
  `${baseUrl.replace(/\/?$/, '/')}${path.replace(/^\/+/, '')}`
const cliDocsUrl = appendDocsPath(docsUrl, 'usage/cli')
const scrimClassName = className.includes('app-release-header')
  ? 'site-header-scrim app-release-header-scrim'
  : 'site-header-scrim'
const brandMarkLight = createMobiusSvg({
  mode: 'light',
  noBackground: true,
  shadow: false,
  size: 96,
  theme: 'metal',
  title: 'One Works mark'
}).replace(/^<\?xml[^>]*>\s*/, '')
const brandMarkDark = createMobiusSvg({
  mode: 'dark',
  noBackground: true,
  shadow: false,
  size: 96,
  theme: 'metal',
  title: 'One Works mark'
}).replace(/^<\?xml[^>]*>\s*/, '')
---

<div class={scrimClassName} aria-hidden="true"></div>
<header class={className} aria-label="Site header">
  <a class={brandClassName} href="/" aria-label="One Works home">
    <span
      class="site-header-brand-mark site-header-brand-mark--light"
      aria-hidden="true"
      set:html={brandMarkLight}
    ></span>
    <span
      class="site-header-brand-mark site-header-brand-mark--dark"
      aria-hidden="true"
      set:html={brandMarkDark}
    ></span>
    <span>One Works</span>
  </a>
  <nav class="top-nav" aria-label="Primary navigation">
    <a href={docsUrl} {...i18nAttrs('nav.docs')}>文档</a>
    <a href="/blog/" {...i18nAttrs('nav.blog')}>博客</a>
    <details class="nav-product-menu">
      <summary>
        <span {...i18nAttrs('nav.product')}>产品</span>
      </summary>
      <div class="nav-product-panel">
        <a href="/app/">
          <span class="nav-product-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M7 4.5h10a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-11a2 2 0 0 1 2-2Z" />
              <path d="M9 17h6" />
            </svg>
          </span>
          <span {...i18nAttrs('nav.app')}>App</span>
        </a>
        <a href={pwaUrl}>
          <span class="nav-product-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
              <path d="M3.7 9h16.6M3.7 15h16.6M12 3c2.2 2.3 3.3 5.3 3.3 9s-1.1 6.7-3.3 9c-2.2-2.3-3.3-5.3-3.3-9S9.8 5.3 12 3Z" />
            </svg>
          </span>
          <span {...i18nAttrs('nav.pwa')}>PWA</span>
        </a>
        <a href={cliDocsUrl}>
          <span class="nav-product-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M4.5 6.5h15v11h-15Z" />
              <path d="m8 10 2 2-2 2M12 14h4" />
            </svg>
          </span>
          <span {...i18nAttrs('nav.cli')}>CLI</span>
        </a>
      </div>
    </details>
  </nav>
  <div class="header-actions">
    <details class="language-menu" data-language-menu>
      <summary
        class="header-icon-button language-trigger"
        aria-label="选择语言"
        title="选择语言"
        data-language-trigger
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
            d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0c2.1-2.1 3.15-5.1 3.15-9S14.1 5.1 12 3m0 18c-2.1-2.1-3.15-5.1-3.15-9S9.9 5.1 12 3M3.6 9h16.8M3.6 15h16.8"
          />
        </svg>
      </summary>
      <div class="language-panel" role="menu" aria-label="Language">
        <button
          class="language-option"
          type="button"
          role="menuitemradio"
          data-language-option="zh"
        >
          中文
        </button>
        <button
          class="language-option"
          type="button"
          role="menuitemradio"
          data-language-option="en"
        >
          English
        </button>
      </div>
    </details>
    <a
      class="header-icon-button github-link"
      href={githubUrl}
      aria-label="Open One Works on GitHub"
      title="GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 2C6.48 2 2 6.58 2 12.26c0 4.54 2.87 8.39 6.84 9.75.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.46-1.19-1.12-1.5-1.12-1.5-.91-.64.07-.63.07-.63 1.01.07 1.54 1.06 1.54 1.06.9 1.58 2.36 1.12 2.94.86.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.38 9.38 0 0 1 12 7c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.38-.01 2.49-.01 2.81 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"
        />
      </svg>
    </a>
  </div>
  {
    showCornerDownload
      ? (
      <a
        class="header-icon-button room-corner-download"
        href={downloadUrl}
        data-homepage-download-link
        aria-label="下载 One Works"
        title="下载 One Works"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.9"
            d="M12 3v11m0 0 4.2-4.2M12 14 7.8 9.8M5 18.5h14"
          />
        </svg>
      </a>
    )
    : null
  }
</header>
