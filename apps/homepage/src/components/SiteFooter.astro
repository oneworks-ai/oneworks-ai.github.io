---
import { createMobiusSvg } from '@oneworks/icon/svg'

type Props = {
  docsUrl?: string
  downloadUrl?: string
  i18n?: boolean
}

const {
  docsUrl = import.meta.env.PUBLIC_DOCS_URL ?? '/docs/',
  downloadUrl = 'https://github.com/oneworks-ai/app/releases',
  i18n = false
} = Astro.props

const i18nAttrs = (key: string) => i18n ? { 'data-i18n': key } : {}
const footerMarkLight = createMobiusSvg({
  mode: 'light',
  noBackground: true,
  shadow: false,
  size: 96,
  theme: 'metal',
  title: 'One Works mark'
}).replace(/^<\?xml[^>]*>\s*/, '')
const footerMarkDark = createMobiusSvg({
  mode: 'dark',
  noBackground: true,
  shadow: false,
  size: 96,
  theme: 'metal',
  title: 'One Works mark'
}).replace(/^<\?xml[^>]*>\s*/, '')
---

<footer class="site-footer" aria-label="One Works footer">
  <div class="footer-content">
    <div class="footer-intro">
      <a
        class="footer-brand"
        href="/"
        target="_blank"
        rel="noreferrer"
        aria-label="One Works home"
      >
        <span
          class="footer-brand-mark footer-brand-mark--light"
          aria-hidden="true"
          set:html={footerMarkLight}
        ></span>
        <span
          class="footer-brand-mark footer-brand-mark--dark"
          aria-hidden="true"
          set:html={footerMarkDark}
        ></span>
        <span>One Works</span>
      </a>
      <p {...i18nAttrs('footer.tagline')}>一个应用，调度你的 AI 编程伙伴。</p>
    </div>

    <div class="footer-note">
      <h2 {...i18nAttrs('footer.note.title')}>请注意</h2>
      <p {...i18nAttrs('footer.note.model')}>
        One Works 会连接由大语言模型驱动的 AI
        编程伙伴。模型回复、总结和工具调用结果可能不准确、不完整或过时，请在执行重要操作前自行确认。
      </p>
      <p {...i18nAttrs('footer.note.local')}>
        真实的本地项目访问、终端执行、IM 连接和多设备接管需要安装 One Works
        桌面端，并按你的授权范围运行。
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-legal">
      <p {...i18nAttrs('footer.copyright')}>© 2026 One Works. 保留所有权利。</p>
      <nav class="footer-links" aria-label="Footer links">
        <a
          href={docsUrl}
          target="_blank"
          rel="noreferrer"
          {...i18nAttrs('footer.links.docs')}
        >文档</a>
        <a
          href={downloadUrl}
          target="_blank"
          rel="noreferrer"
          data-homepage-download-link
          {...i18nAttrs('footer.links.download')}
        >
          下载
        </a>
        <a
          href="https://discord.gg/eXV5KEBP6A"
          target="_blank"
          rel="noreferrer"
          {...i18nAttrs('footer.links.support')}
        >支持</a>
        <a
          href="https://oneworks-ai.github.io/pwa/"
          target="_blank"
          rel="noreferrer"
        >PWA</a>
      </nav>
    </div>

    <nav class="footer-social" aria-label="Footer quick links">
      <a
        href="https://github.com/oneworks-ai/app"
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
        title="GitHub"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.58 2 12.26c0 4.54 2.87 8.39 6.84 9.75.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.46-1.19-1.12-1.5-1.12-1.5-.91-.64.07-.63.07-.63 1.01.07 1.54 1.06 1.54 1.06.9 1.58 2.36 1.12 2.94.86.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.38 9.38 0 0 1 12 7c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.38-.01 2.49-.01 2.81 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"
          />
        </svg>
      </a>
      <a
        class="footer-social-discord"
        href="https://discord.gg/eXV5KEBP6A"
        target="_blank"
        rel="noreferrer"
        aria-label="Discord"
        title="Discord"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M19.54 5.34a17.4 17.4 0 0 0-4.35-1.35.07.07 0 0 0-.08.04c-.19.34-.4.79-.55 1.14a16.2 16.2 0 0 0-4.85 0 11.1 11.1 0 0 0-.56-1.14.08.08 0 0 0-.08-.04c-1.5.26-2.96.72-4.35 1.35a.07.07 0 0 0-.03.03C1.93 9.48 1.18 13.48 1.55 17.43c0 .02.01.04.03.05a17.5 17.5 0 0 0 5.33 2.69.08.08 0 0 0 .09-.03c.41-.56.78-1.15 1.1-1.77a.08.08 0 0 0-.04-.11 11.5 11.5 0 0 1-1.67-.8.08.08 0 0 1 0-.13c.11-.08.22-.17.33-.26a.07.07 0 0 1 .08-.01c3.45 1.58 7.2 1.58 10.61 0a.07.07 0 0 1 .08.01c.11.09.22.18.34.26a.08.08 0 0 1 0 .13c-.53.31-1.08.58-1.67.8a.08.08 0 0 0-.04.11c.32.62.69 1.21 1.1 1.77a.08.08 0 0 0 .09.03 17.45 17.45 0 0 0 5.34-2.69.08.08 0 0 0 .03-.05c.45-4.57-.75-8.54-3.1-12.06a.06.06 0 0 0-.04-.03ZM8.44 15.02c-1.04 0-1.9-.96-1.9-2.14 0-1.18.84-2.14 1.9-2.14 1.07 0 1.92.97 1.9 2.14 0 1.18-.84 2.14-1.9 2.14Zm7.14 0c-1.04 0-1.9-.96-1.9-2.14 0-1.18.84-2.14 1.9-2.14 1.07 0 1.92.97 1.9 2.14 0 1.18-.83 2.14-1.9 2.14Z"
          />
        </svg>
      </a>
      <a
        href="https://t.me/oneworksai"
        target="_blank"
        rel="noreferrer"
        aria-label="Telegram"
        title="Telegram"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 5 4.8 10.9c-.9.35-.88 1.02-.16 1.24l3.9 1.22 1.5 4.72c.18.52.34.72.7.72.36 0 .52-.16.72-.35l2.16-2.1 4.48 3.3c.82.45 1.4.22 1.6-.76L22.6 6.1c.3-1.24-.48-1.8-1.38-1.38Z" />
          <path d="m8.7 13.25 8.88-5.6-6.92 7.24-.26 3.02" />
        </svg>
      </a>
      <a
        href={docsUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="Docs"
        title="Docs"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 4.5h8.5L18 8v11.5H6z" />
          <path d="M14.5 4.5V8H18M9 12h6M9 15h6M9 18h4" />
        </svg>
      </a>
      <a
        href={downloadUrl}
        target="_blank"
        rel="noreferrer"
        data-homepage-download-link
        aria-label="Download"
        title="Download"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 4v10m0 0 4-4m-4 4-4-4M5 19h14" />
        </svg>
      </a>
      <a
        href="https://oneworks-ai.github.io/pwa/"
        target="_blank"
        rel="noreferrer"
        aria-label="PWA"
        title="PWA"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
          <path d="M3.7 9h16.6M3.7 15h16.6M12 3c2.2 2.3 3.3 5.3 3.3 9s-1.1 6.7-3.3 9c-2.2-2.3-3.3-5.3-3.3-9S9.8 5.3 12 3Z" />
        </svg>
      </a>
    </nav>
  </div>
</footer>
