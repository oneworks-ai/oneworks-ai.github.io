---
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'
import PageLayout from '../layouts/PageLayout.astro'
import {
  githubReleasesUrl,
  loadDesktopReleases
} from '../utils/desktop-releases'

const desktopReleases = await loadDesktopReleases()
const desktopReleaseData = JSON.stringify(desktopReleases).replace(
  /</g,
  '\\u003c'
)
---

<PageLayout title="One Works App">
  <main class="app-release-shell">
    <SiteHeader
      brandClassName="app-release-brand"
      className="site-header app-release-header"
    />

    <section class="app-download-panel" aria-labelledby="app-download-title">
      <div class="app-download-copy">
        <h1 id="app-download-title">桌面端下载</h1>
        <p>
          按通道、操作系统和版本选择安装包。这里展示已经发布到 GitHub Releases
          的桌面端资源。
        </p>
      </div>

      <div class="app-download-controls" aria-label="下载选项">
        <div class="app-download-control">
          <span class="app-download-label">通道</span>
          <div class="app-channel-tabs" role="tablist" aria-label="发布通道">
            <button type="button" data-channel-option="stable">
              <span class="app-channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 3.2 19 6v5.5c0 4.3-2.8 7.7-7 9.3-4.2-1.6-7-5-7-9.3V6l7-2.8Z" />
                  <path d="m8.8 12 2.1 2.1 4.4-4.6" />
                </svg>
              </span>
              <span>Stable</span>
            </button>
            <button type="button" data-channel-option="alpha">
              <span class="app-channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M10 3h4" />
                  <path d="M11 3v5l-5.7 9.7A2.2 2.2 0 0 0 7.2 21h9.6a2.2 2.2 0 0 0 1.9-3.3L13 8V3" />
                  <path d="M8.5 16h7" />
                </svg>
              </span>
              <span>Alpha</span>
            </button>
            <button type="button" data-channel-option="beta">
              <span class="app-channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M7 4v16" />
                  <path d="M7 6h5.5a3.5 3.5 0 0 1 0 7H7" />
                  <path d="M7 13h6a3.5 3.5 0 0 1 0 7H7" />
                </svg>
              </span>
              <span>Beta</span>
            </button>
            <button type="button" data-channel-option="rc">
              <span class="app-channel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M5 21V4" />
                  <path d="M5 5h11l-1.2 3L16 11H5" />
                </svg>
              </span>
              <span>RC</span>
            </button>
          </div>
        </div>

        <div class="app-download-control">
          <span class="app-download-label">操作系统</span>
          <div class="app-platform-tabs" role="tablist" aria-label="操作系统">
            <button type="button" data-platform-option="mac">
              <span
                class="app-platform-icon app-platform-icon--solid"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M16.3 2.4c.1 1.2-.4 2.4-1.2 3.3-.8.9-2.1 1.5-3.2 1.4-.1-1.2.4-2.4 1.2-3.2.8-.9 2.1-1.5 3.2-1.5Z" />
                  <path d="M19.5 17.7c-.4.9-.6 1.3-1.2 2.1-.8 1.1-1.9 2.5-3.3 2.5-1.2 0-1.5-.8-3.1-.8s-2 .8-3.2.8c-1.4 0-2.5-1.3-3.3-2.5-2.3-3.2-2.5-7-.9-9.1 1.1-1.5 2.9-2.4 4.6-2.4 1.4 0 2.8.8 3.1.8.2 0 1.8-.9 3.4-.8.7 0 2.7.3 4 2.2-3.5 1.9-2.9 6.1-.1 7.2Z" />
                </svg>
              </span>
              <span>macOS</span>
            </button>
            <button type="button" data-platform-option="linux">
              <span class="app-platform-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 2.5c-2.1 0-3.8 1.6-3.8 3.7v3.5c0 .8-.2 1.6-.5 2.3l-2 4.2c-.5 1-.1 2.1.9 2.6l2.4 1.1c.7.3 1.5 0 1.8-.7l.2-.5h2l.2.5c.3.7 1.1 1 1.8.7l2.4-1.1c1-.5 1.4-1.6.9-2.6l-2-4.2c-.3-.7-.5-1.5-.5-2.3V6.2c0-2.1-1.7-3.7-3.8-3.7Z" />
                  <path d="M9.9 7.1h.1M14 7.1h.1" />
                  <path d="M10.6 12.5h2.8l.6 2.8h-4l.6-2.8Z" />
                  <path d="M7.8 18.2l2.4-1.4M16.2 18.2l-2.4-1.4" />
                </svg>
              </span>
              <span>Linux</span>
            </button>
            <button type="button" data-platform-option="windows">
              <span
                class="app-platform-icon app-platform-icon--solid"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M3.5 5.4 10.5 4v7.2h-7V5.4ZM12 3.7l8.5-1.6v9.1H12V3.7ZM3.5 12.8h7v7.2l-7-1.4v-5.8ZM12 12.8h8.5v9.1L12 20.3v-7.5Z" />
                </svg>
              </span>
              <span>Windows</span>
            </button>
          </div>
        </div>

        <label class="app-download-control">
          <span class="app-download-label">版本</span>
          <select data-release-version-select aria-label="选择版本"></select>
        </label>
      </div>

      <div class="app-download-result" data-app-download-result>
        <div>
          <p class="app-download-selected">
            <a data-app-download-selected>正在准备下载选项...</a>
          </p>
          <p class="app-download-meta" data-app-download-meta></p>
        </div>
        <div class="app-download-assets" data-app-download-assets></div>
      </div>

      <p class="app-download-empty" data-app-download-empty hidden>
        当前系统没有可用安装包。你可以切换系统或前往全部版本查看。
      </p>
    </section>

    <section class="app-version-list" aria-label="可用桌面端版本">
      <div class="app-version-list-header">
        <h2>可用版本</h2>
        <a href={githubReleasesUrl} target="_blank" rel="noreferrer"
        >GitHub Releases</a>
      </div>
      <div class="app-version-table" data-app-version-table></div>
    </section>

    <script
      id="app-release-data"
      type="application/json"
      is:inline
      set:html={desktopReleaseData}
    >
    </script>
  </main>
  <SiteFooter />

  <script>
  const initializeAppReleasePage = () => {
    type DownloadArchitecture = 'arm64' | 'unknown' | 'x64'
    type DownloadChannel = 'alpha' | 'beta' | 'rc' | 'stable'
    type DownloadPlatform = 'linux' | 'mac' | 'windows'
    type DesktopReleaseAsset = {
      architecture: DownloadArchitecture
      downloadUrl: string
      format: string
      name: string
      platform: DownloadPlatform
      size: number
    }
    type DesktopRelease = {
      assets: DesktopReleaseAsset[]
      channel: DownloadChannel
      detailUrl: string
      prerelease: boolean
      publishedAt: string
      releaseUrl: string
      slug: string
      tagName: string
      title: string
    }
    type UserAgentDataLike = {
      getHighEntropyValues?: (
        hints: Array<'architecture' | 'platform'>
      ) => Promise<{ architecture?: string; platform?: string }>
      platform?: string
    }

    const releaseDataScript = document.querySelector<HTMLScriptElement>(
      '#app-release-data'
    )
    if (
      releaseDataScript == null ||
      releaseDataScript.dataset.appReleaseInitialized === 'true'
    ) {
      return
    }

    releaseDataScript.dataset.appReleaseInitialized = 'true'
    const channelButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-channel-option]')
    )
    const platformButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-platform-option]')
    )
    const versionSelect = document.querySelector<HTMLSelectElement>(
      '[data-release-version-select]'
    )
    const selectedLabel = document.querySelector<HTMLAnchorElement>(
      '[data-app-download-selected]'
    )
    const selectedMeta = document.querySelector<HTMLElement>(
      '[data-app-download-meta]'
    )
    const assetList = document.querySelector<HTMLElement>(
      '[data-app-download-assets]'
    )
    const emptyState = document.querySelector<HTMLElement>(
      '[data-app-download-empty]'
    )
    const versionTable = document.querySelector<HTMLElement>(
      '[data-app-version-table]'
    )
    const releases: DesktopRelease[] = (() => {
      try {
        const parsedValue = JSON.parse(releaseDataScript?.textContent ?? '[]')
        return Array.isArray(parsedValue)
          ? parsedValue as DesktopRelease[]
          : []
      } catch (error) {
        void error
        return []
      }
    })()

    const parseChannelParam = (
      value: string | null
    ): DownloadChannel | undefined => {
      const normalizedValue = value?.trim().toLowerCase()
      if (
        normalizedValue === 'alpha' ||
        normalizedValue === 'beta' ||
        normalizedValue === 'rc' ||
        normalizedValue === 'stable'
      ) {
        return normalizedValue
      }
      return undefined
    }
    const parsePlatformParam = (
      value: string | null
    ): DownloadPlatform | undefined => {
      const normalizedValue = value?.trim().toLowerCase()
      if (
        normalizedValue === 'mac' || normalizedValue === 'macos' ||
        normalizedValue === 'darwin'
      ) {
        return 'mac'
      }
      if (normalizedValue === 'linux' || normalizedValue === 'windows') {
        return normalizedValue
      }
      return undefined
    }
    const serializePlatformParam = (platform: DownloadPlatform) => {
      if (platform === 'mac') {
        return 'macos'
      }
      return platform
    }
    const findReleaseByVersionParam = (value: string | null) => {
      const normalizedValue = value?.trim()
      if (normalizedValue == null || normalizedValue === '') {
        return undefined
      }
      return releases.find((release) => {
        return release.slug === normalizedValue ||
          release.title === normalizedValue ||
          release.tagName === normalizedValue
      })
    }
    const initialUrlState = (() => {
      const params = new URLSearchParams(window.location.search)
      const versionValue = params.get('version')?.trim() || undefined
      const versionRelease = findReleaseByVersionParam(versionValue ?? null)
      return {
        channel: parseChannelParam(params.get('channel')) ??
          versionRelease?.channel,
        platform: parsePlatformParam(params.get('platform')),
        versionTagName: versionRelease?.tagName ?? versionValue
      }
    })()
    let activeChannel: DownloadChannel = initialUrlState.channel ?? 'stable'
    let activePlatform: DownloadPlatform = initialUrlState.platform ?? 'mac'
    let preferredVersionTagName = initialUrlState.versionTagName

    const channelLabel = (channel: DownloadChannel) => {
      if (channel === 'stable') {
        return 'Stable'
      }
      if (channel === 'alpha') {
        return 'Alpha'
      }
      if (channel === 'beta') {
        return 'Beta'
      }
      return 'RC'
    }

    const platformLabel = (platform: DownloadPlatform) => {
      if (platform === 'mac') {
        return 'macOS'
      }
      if (platform === 'linux') {
        return 'Linux'
      }
      return 'Windows'
    }
    const architectureLabel = (architecture: DownloadArchitecture) => {
      if (architecture === 'arm64') {
        return 'Apple Silicon / ARM64'
      }
      if (architecture === 'x64') {
        return 'Intel / x64'
      }
      return '通用'
    }
    const formatAssetSize = (size: number) => {
      if (!Number.isFinite(size) || size <= 0) {
        return ''
      }

      const megaBytes = size / 1024 / 1024
      return `${megaBytes.toFixed(megaBytes >= 100 ? 0 : 1)} MB`
    }
    const formatDate = (value: string) => {
      if (value.trim() === '') {
        return ''
      }

      const date = new Date(value)
      if (Number.isNaN(date.getTime())) {
        return ''
      }

      return new Intl.DateTimeFormat('zh-CN', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      }).format(date)
    }
    const getNavigatorUserAgentData = () => {
      return (navigator as Navigator & { userAgentData?: UserAgentDataLike })
        .userAgentData
    }
    const detectPlatform = async (): Promise<DownloadPlatform> => {
      const uaData = getNavigatorUserAgentData()
      let highEntropyValues:
        | { architecture?: string; platform?: string }
        | undefined
      try {
        highEntropyValues = await uaData?.getHighEntropyValues?.([
          'architecture',
          'platform'
        ])
      } catch (error) {
        void error
      }

      const platformText = [
        navigator.platform,
        navigator.userAgent,
        uaData?.platform,
        highEntropyValues?.platform
      ].filter(Boolean).join(' ').toLowerCase()
      if (platformText.includes('win')) {
        return 'windows'
      }
      if (platformText.includes('linux')) {
        return 'linux'
      }
      return 'mac'
    }
    const getReleasesForPlatform = (platform: DownloadPlatform) => {
      return releases.filter((release) => {
        return release.channel === activeChannel &&
          release.assets.some((asset) => asset.platform === platform)
      })
    }
    const getReleasesForChannel = () => {
      return releases.filter((release) => release.channel === activeChannel)
    }
    const getSelectedRelease = () => {
      return releases.find((release) =>
        release.tagName === versionSelect?.value
      )
    }
    const updateUrlState = () => {
      const url = new URL(window.location.href)
      const release = getSelectedRelease()
      url.searchParams.set('channel', activeChannel)
      url.searchParams.set('platform', serializePlatformParam(activePlatform))
      if (release == null) {
        url.searchParams.delete('version')
      } else {
        url.searchParams.set('version', release.slug)
      }

      const nextUrl = `${url.pathname}${url.search}${url.hash}`
      const currentUrl =
        `${window.location.pathname}${window.location.search}${window.location.hash}`
      if (nextUrl !== currentUrl) {
        window.history.replaceState(window.history.state, '', nextUrl)
      }
    }
    const createElement = <K extends keyof HTMLElementTagNameMap>(
      tagName: K,
      className?: string,
      text?: string
    ) => {
      const element = document.createElement(tagName)
      if (className != null) {
        element.className = className
      }
      if (text != null) {
        element.textContent = text
      }
      return element
    }
    const renderVersionSelect = () => {
      if (versionSelect == null) {
        return
      }

      const previousValue = preferredVersionTagName ?? versionSelect.value
      const platformReleases = getReleasesForPlatform(activePlatform)
      versionSelect.replaceChildren(...platformReleases.map((release) => {
        const option = document.createElement('option')
        option.value = release.tagName
        option.textContent = `${release.title} · ${
          channelLabel(release.channel)
        }`
        return option
      }))
      if (
        platformReleases.some((release) => release.tagName === previousValue)
      ) {
        versionSelect.value = previousValue
      }
      preferredVersionTagName = versionSelect.value || undefined
      versionSelect.disabled = platformReleases.length === 0
    }
    const renderAssets = () => {
      if (
        selectedLabel == null ||
        selectedMeta == null ||
        assetList == null ||
        emptyState == null
      ) {
        return
      }

      const release = getSelectedRelease()
      const assets =
        release?.assets.filter((asset) =>
          asset.platform === activePlatform
        ) ?? []
      emptyState.hidden = assets.length > 0
      assetList.replaceChildren()
      if (release == null || assets.length === 0) {
        selectedLabel.textContent = `${channelLabel(activeChannel)} / ${
          platformLabel(activePlatform)
        } 暂无可下载版本`
        selectedLabel.removeAttribute('href')
        selectedLabel.removeAttribute('aria-label')
        selectedMeta.textContent =
          '可以切换通道、操作系统，或进入版本详情查看全部资源。'
        return
      }

      selectedLabel.textContent = `${channelLabel(release.channel)} / ${
        platformLabel(activePlatform)
      } · ${release.title}`
      selectedLabel.href = release.detailUrl
      selectedLabel.setAttribute(
        'aria-label',
        `查看 ${release.title} 版本详情`
      )
      selectedMeta.textContent = [
        formatDate(release.publishedAt),
        '当前系统资源'
      ].filter(Boolean).join(' · ')

      const sortedAssets = [...assets].sort((left, right) => {
        const architectureOrder = { arm64: 0, x64: 1, unknown: 2 }
        return architectureOrder[left.architecture] -
            architectureOrder[right.architecture] ||
          left.format.localeCompare(right.format)
      })
      for (const asset of sortedAssets) {
        const link = createElement(
          'a',
          'app-download-asset'
        ) as HTMLAnchorElement
        link.href = asset.downloadUrl
        link.download = asset.name
        const label = createElement('span', 'app-download-asset__label')
        label.textContent = `${
          architectureLabel(asset.architecture)
        } · ${asset.format}`
        const size = createElement(
          'span',
          'app-download-asset__size',
          formatAssetSize(asset.size)
        )
        link.append(label, size)
        assetList.append(link)
      }
    }
    const renderChannelButtons = () => {
      for (const button of channelButtons) {
        const isActive = button.dataset.channelOption === activeChannel
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', String(isActive))
      }
    }
    const renderPlatformButtons = () => {
      for (const button of platformButtons) {
        const isActive = button.dataset.platformOption === activePlatform
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', String(isActive))
      }
    }
    const renderVersionTable = () => {
      if (versionTable == null) {
        return
      }

      const channelReleases = getReleasesForChannel()
      versionTable.replaceChildren(
        ...channelReleases.slice(0, 12).map((release) => {
          const row = createElement(
            'a',
            'app-version-row'
          ) as HTMLAnchorElement
          row.href = release.detailUrl
          const title = createElement(
            'span',
            'app-version-row__title',
            release.title
          )
          const systems = createElement('span', 'app-version-row__systems')
          const platforms = Array.from(
            new Set(release.assets.map((asset) => asset.platform))
          )
          systems.textContent = platforms.map(platformLabel).join(' / ')
          const channel = createElement(
            'span',
            release.prerelease
              ? 'app-version-row__channel is-pre'
              : 'app-version-row__channel',
            channelLabel(release.channel)
          )
          const arrow = createElement('span', 'app-version-row__arrow')
          row.append(title, systems, channel, arrow)
          return row
        })
      )
    }
    const render = () => {
      renderChannelButtons()
      renderPlatformButtons()
      renderVersionSelect()
      renderAssets()
      renderVersionTable()
      updateUrlState()
    }

    for (const button of channelButtons) {
      button.addEventListener('click', () => {
        const channel = button.dataset.channelOption as
          | DownloadChannel
          | undefined
        if (channel == null) {
          return
        }
        activeChannel = channel
        preferredVersionTagName = undefined
        render()
      })
    }

    for (const button of platformButtons) {
      button.addEventListener('click', () => {
        const platform = button.dataset.platformOption as
          | DownloadPlatform
          | undefined
        if (platform == null) {
          return
        }
        activePlatform = platform
        render()
      })
    }
    versionSelect?.addEventListener('change', () => {
      preferredVersionTagName = versionSelect.value
      renderAssets()
      updateUrlState()
    })

    if (initialUrlState.platform == null) {
      void detectPlatform().then((platform) => {
        activePlatform = platform
        render()
      })
    } else {
      render()
    }
  }

  initializeAppReleasePage()
  document.addEventListener('astro:page-load', initializeAppReleasePage)
  </script>
</PageLayout>
