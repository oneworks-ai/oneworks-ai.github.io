---
import SiteFooter from '../../components/SiteFooter.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import PageLayout from '../../layouts/PageLayout.astro'
import {
  type DesktopRelease,
  type DesktopReleaseAsset,
  type DownloadArchitecture,
  type DownloadPlatform,
  loadDesktopReleases
} from '../../utils/desktop-releases'

export async function getStaticPaths() {
  const releases = await loadDesktopReleases()
  return releases.map((release) => ({
    params: { version: release.slug },
    props: { release }
  }))
}

const { release } = Astro.props as { release: DesktopRelease }
const platformOrder: DownloadPlatform[] = ['mac', 'linux', 'windows']

const platformLabel = (platform: DownloadPlatform) => {
  if (platform === 'mac') {
    return 'macOS'
  }
  if (platform === 'linux') {
    return 'Linux'
  }
  return 'Windows'
}

const architectureLabel = (architecture: DownloadArchitecture) => {
  if (architecture === 'arm64') {
    return 'Apple Silicon / ARM64'
  }
  if (architecture === 'x64') {
    return 'Intel / x64'
  }
  return '通用'
}

const formatAssetSize = (size: number) => {
  if (!Number.isFinite(size) || size <= 0) {
    return ''
  }

  const megaBytes = size / 1024 / 1024
  return `${megaBytes.toFixed(megaBytes >= 100 ? 0 : 1)} MB`
}

const formatDate = (value: string) => {
  if (value.trim() === '') {
    return ''
  }

  const date = new Date(value)
  if (Number.isNaN(date.getTime())) {
    return ''
  }

  return new Intl.DateTimeFormat('zh-CN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  }).format(date)
}

const assetSortKey = (asset: DesktopReleaseAsset) => {
  const architectureOrder = { arm64: 0, x64: 1, unknown: 2 }
  return `${
    architectureOrder[asset.architecture]
  }-${asset.format}-${asset.name}`
}

const groupedPlatforms = platformOrder
  .map((platform) => ({
    assets: release.assets
      .filter((asset) => asset.platform === platform)
      .sort((left, right) =>
        assetSortKey(left).localeCompare(assetSortKey(right))
      ),
    platform
  }))
  .filter((group) => group.assets.length > 0)

const releaseDate = formatDate(release.publishedAt)
---

<PageLayout title={`One Works ${release.title}`}>
  <main class="app-release-shell">
    <SiteHeader
      brandClassName="app-release-brand"
      className="site-header app-release-header"
    />

    <article
      class="app-release-detail"
      aria-labelledby="app-release-detail-title"
    >
      <div class="app-release-detail-header">
        <div class="app-release-detail-copy">
          <nav class="app-release-breadcrumb" aria-label="面包屑">
            <a
              class="app-release-detail-back"
              href="/app/"
              aria-label="返回下载页"
              title="返回下载页"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M15 5 8 12l7 7" />
              </svg>
            </a>
            <a href="/app/">桌面端下载</a>
            <span aria-hidden="true">/</span>
            <span>{release.title}</span>
          </nav>
          <h1 id="app-release-detail-title">One Works {release.title}</h1>
          <p>
            {release.prerelease ? '预发布版本' : '稳定版本'}
            {releaseDate !== '' ? ` · ${releaseDate}` : ''}
            · {release.assets.length} 个安装包
          </p>
        </div>
      </div>

      <div class="app-release-detail-platforms">
        {
          groupedPlatforms.map((group) => (
            <section
              class="app-release-detail-platform"
              aria-labelledby={`platform-${group.platform}`}
            >
              <div class="app-release-detail-platform__header">
                <h2 id={`platform-${group.platform}`}>
                  <span
                    class:list={[
                      'app-platform-icon',
                      group.platform !== 'linux' &&
                      'app-platform-icon--solid'
                    ]}
                    aria-hidden="true"
                  >
                    {
                      group.platform === 'mac' && (
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M16.3 2.4c.1 1.2-.4 2.4-1.2 3.3-.8.9-2.1 1.5-3.2 1.4-.1-1.2.4-2.4 1.2-3.2.8-.9 2.1-1.5 3.2-1.5Z" />
                          <path d="M19.5 17.7c-.4.9-.6 1.3-1.2 2.1-.8 1.1-1.9 2.5-3.3 2.5-1.2 0-1.5-.8-3.1-.8s-2 .8-3.2.8c-1.4 0-2.5-1.3-3.3-2.5-2.3-3.2-2.5-7-.9-9.1 1.1-1.5 2.9-2.4 4.6-2.4 1.4 0 2.8.8 3.1.8.2 0 1.8-.9 3.4-.8.7 0 2.7.3 4 2.2-3.5 1.9-2.9 6.1-.1 7.2Z" />
                        </svg>
                      )
                    }
                    {
                                        group.platform === 'linux' && (
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 2.5c-2.1 0-3.8 1.6-3.8 3.7v3.5c0 .8-.2 1.6-.5 2.3l-2 4.2c-.5 1-.1 2.1.9 2.6l2.4 1.1c.7.3 1.5 0 1.8-.7l.2-.5h2l.2.5c.3.7 1.1 1 1.8.7l2.4-1.1c1-.5 1.4-1.6.9-2.6l-2-4.2c-.3-.7-.5-1.5-.5-2.3V6.2c0-2.1-1.7-3.7-3.8-3.7Z" />
                          <path d="M9.9 7.1h.1M14 7.1h.1" />
                          <path d="M10.6 12.5h2.8l.6 2.8h-4l.6-2.8Z" />
                          <path d="M7.8 18.2l2.4-1.4M16.2 18.2l-2.4-1.4" />
                        </svg>
                      )
                    }
                    {
                                        group.platform === 'windows' && (
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M3.5 5.4 10.5 4v7.2h-7V5.4ZM12 3.7l8.5-1.6v9.1H12V3.7ZM3.5 12.8h7v7.2l-7-1.4v-5.8ZM12 12.8h8.5v9.1L12 20.3v-7.5Z" />
                        </svg>
                      )
                    }
                  </span>
                  <span>{platformLabel(group.platform)}</span>
                </h2>
                <span>{group.assets.length} 个资源</span>
              </div>
              <div class="app-release-detail-assets">
                {
                  group.assets.map((asset) => (
                    <a
                      class="app-release-detail-asset"
                      href={asset.downloadUrl}
                      download={asset.name}
                    >
                      <span class="app-release-detail-asset__name">{
                        asset.name
                      }</span>
                      <span class="app-release-detail-asset__meta">
                        {architectureLabel(asset.architecture)} · {asset.format}
                        {
                          formatAssetSize(asset.size) !== ''
                            ? ` · ${formatAssetSize(asset.size)}`
                            : ''
                        }
                      </span>
                    </a>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
    </article>
  </main>
  <SiteFooter />
</PageLayout>
